# Delay start until qseecomd is ready (sync with gatekeeper trigger)
on property:vendor.gatekeeper.is_security_level_spu=0
    start vendor.keymint-qti

service vendor.keymint-qti /vendor/bin/hw/android.hardware.security.keymint-service-spu-qti
    class early_hal
    user root
    group root drmrpc
    seclabel u:r:vendor_hal_keymint_spu_qti:s0

on property:vendor.car.hiber=hiberExit
    stop vendor.keymint-qti
    start vendor.keymint-qti
    stop keystore2
    start keystore2
