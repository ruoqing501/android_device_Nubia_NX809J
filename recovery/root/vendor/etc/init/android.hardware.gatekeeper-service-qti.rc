service vendor.gatekeeper_default /vendor/bin/hw/android.hardware.gatekeeper-service-spu-qti
    class early_hal
    user root
    group root
    disabled
    seclabel u:r:vendor_hal_gatekeeper_spu_qti:s0

on property:vendor.gatekeeper.is_security_level_spu=0
    enable vendor.gatekeeper_default
