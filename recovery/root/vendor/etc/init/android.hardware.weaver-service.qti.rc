# Delay start until qseecomd is ready (sync with gatekeeper trigger)
on property:vendor.gatekeeper.is_security_level_spu=0
    start vendor.weaver-service

service vendor.weaver-service /vendor/bin/hw/android.hardware.weaver-service-spu-qti
    class hal
    user root
    group nfc root
    seclabel u:r:vendor_hal_weaver_spu_qti:s0
